# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-west-1

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_API_VERSION=v3

# S3 Buckets
S3_RAW_BUCKET=youtube-raw
S3_CLEANED_BUCKET=youtube-cleaned
S3_ANALYTICS_BUCKET=youtube-analytics
S3_MODELS_BUCKET=youtube-models
S3_QUALITY_REPORTS_BUCKET=youtube-quality-reports

# AWS Glue
GLUE_DATABASE_NAME=youtube_analytics
GLUE_JOB_NAME=youtube_etl_job
GLUE_ROLE_NAME=YouTubeAnalyticsRole

# AWS Lambda
LAMBDA_VALIDATOR_NAME=youtube_data_validator
LAMBDA_ROLE_NAME=YouTubeLambdaRole

# Airflow
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_DB=airflow
AIRFLOW_HOST=localhost

# Monitoring
SNS_TOPIC_ARN=arn:aws:sns:us-west-1:123456789012:youtube-analytics-alerts
CLOUDWATCH_LOG_GROUP=/aws/youtube/analytics

# ML Model Parameters
RANDOM_STATE=42
MODEL_TEST_SIZE=0.2
NLP_ACCURACY_THRESHOLD=0.85
ML_R2_THRESHOLD=0.85

# Data Quality
DATA_QUALITY_THRESHOLD=90
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=5
