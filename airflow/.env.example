# Airflow Configuration
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here-replace-with-actual-key
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__DEFAULT_UI_TIMEZONE=UTC

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-west-1

# S3 Buckets
S3_RAW_BUCKET=youtube-raw
S3_CLEANED_BUCKET=youtube-cleaned
S3_QUALITY_REPORTS_BUCKET=youtube-quality-reports
S3_SCRIPTS_BUCKET=youtube-scripts
S3_LOGS_BUCKET=youtube-logs
S3_TEMP_BUCKET=youtube-temp

# YouTube API
YOUTUBE_API_KEY=your-youtube-api-key

# Slack Configuration
SLACK_WEBHOOK_URL=your-slack-webhook-url

# ML Configuration
ML_R2_THRESHOLD=0.85
NLP_ACCURACY_THRESHOLD=0.85

# Data Quality
DATA_QUALITY_THRESHOLD=90

# Database
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
